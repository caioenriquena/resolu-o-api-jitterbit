# Porta da aplicação
PORT=3000

# Configuração do PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orders_db
DB_USER=order_user
DB_PASSWORD=order_password

# Configurações de segurança / rate limit
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# Autenticação básica para a API de pedidos
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123

# Configuração do JWT
JWT_SECRET=uma_senha_bem_secreta
JWT_EXPIRES_IN=1h

